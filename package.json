{
  "name": "stackorbitai-bulk-writer-pro",
  "version": "1.0.0",
  "description": "StackOrbitAI Bulk Writer Pro - Enterprise AI Bulk Blog Writer",
  "main": "dist/main/index.js",
  "author": "StackOrbitAI",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build:renderer": "vite build --config vite.config.ts",
    "build:main": "tsup src/main/index.ts src/main/preload.ts --out-dir dist/main --format cjs --external electron --external sqlite3",
    "build": "npm run build:renderer && npm run build:main",
    "package": "npm run build && electron-builder --win --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.1.7",
    "express": "^4.19.2",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.395.0",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.7",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "node-gyp": "^10.1.0",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.stackorbitai.bulk-writer-pro",
    "productName": "StackOrbitAI Bulk Writer Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "publish": {
        "provider": "github",
        "owner": "StackOrbitAI",
        "repo": "stackorbitai-bulk-writer-pro",
        "private": false
      }
    },
    "win": {
      "target": [
        "nsis"
      ],
      "publish": {
        "provider": "github",
        "owner": "StackOrbitAI",
        "repo": "stackorbitai-bulk-writer-pro",
        "private": false
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StackOrbitAI Bulk Writer Pro"
    }
  },
  "overrides": {
    "node-gyp": "^10.1.0"
  }
}
